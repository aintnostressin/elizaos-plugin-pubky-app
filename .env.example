# Required — provide one of PUBKY_SEED_PHRASE or PUBKY_SECRET_KEY
PUBKY_SEED_PHRASE=        # BIP39 mnemonic — used to derive the secret key (takes precedence over PUBKY_SECRET_KEY)
PUBKY_SECRET_KEY=         # 32-byte hex secret key (used when PUBKY_SEED_PHRASE is not set)
PUBKY_NEXUS_URL=          # Base URL of the Pubky Nexus API

# Required for first-time account creation; not needed if the account already exists on the homeserver
PUBKY_HOMESERVER_PUBKEY=  # z32-encoded public key of the homeserver

# Optional
PUBKY_DRY_RUN=false  # Set to "true" to skip actual homeserver writes (posts are logged only)
